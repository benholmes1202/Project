@model Project.Models.AccountTransaction

@{
    ViewData["Title"] = "Delete Transaction";
}

<h1 class="h2">Delete Transaction</h1>

<div class="alert alert-warning">
    Deleting this transaction will reverse its effect on the account balance.
</div>

<dl class="row">
    <dt class="col-sm-3">Account</dt>
    <dd class="col-sm-9">@(Model.BettingAccount?.AccountNumber ?? Model.AccountId.ToString())</dd>
    <dt class="col-sm-3">Type</dt>
    <dd class="col-sm-9">@(Model.TransactionType?.Name ?? "-")</dd>
    <dt class="col-sm-3">Amount</dt>
    <dd class="col-sm-9">@Model.Amount.ToString("C")</dd>
    <dt class="col-sm-3">Transaction Date</dt>
    <dd class="col-sm-9">@Model.TransactionDate.ToString("yyyy-MM-dd")</dd>
    <dt class="col-sm-3">Reference</dt>
    <dd class="col-sm-9">@(Model.Reference ?? "-")</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="TransactionId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-outline-secondary" asp-controller="BettingAccounts" asp-action="Details" asp-route-id="@Model.AccountId">Back to Account</a>
</form>
