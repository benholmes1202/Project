@model Project.ViewModels.AccountTransactions.AccountTransactionFormViewModel

@{
    ViewData["Title"] = "Create Transaction";
}

<h1 class="h2">Create Transaction</h1>

<div class="row">
    <div class="col-md-6 col-lg-5">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="AccountId" class="form-label"></label>
                <select asp-for="AccountId" class="form-select" asp-items="ViewBag.AccountId">
                    <option value="">Select an open account</option>
                </select>
                <span asp-validation-for="AccountId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="TransactionTypeId" class="form-label"></label>
                <select asp-for="TransactionTypeId" class="form-select" asp-items="ViewBag.TransactionTypeId">
                    <option value="">Select debit or credit</option>
                </select>
                <span asp-validation-for="TransactionTypeId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Amount" class="form-label"></label>
                <input asp-for="Amount" class="form-control" />
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="TransactionDate" class="form-label"></label>
                <input asp-for="TransactionDate" class="form-control" max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="TransactionDate" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="RelatedBetId" class="form-label"></label>
                <select asp-for="RelatedBetId" class="form-select" asp-items="ViewBag.RelatedBetId">
                    <option value="">No related bet</option>
                </select>
                <span asp-validation-for="RelatedBetId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Reference" class="form-label"></label>
                <input asp-for="Reference" class="form-control" />
                <span asp-validation-for="Reference" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Create</button>
            <a class="btn btn-outline-secondary" asp-controller="BettingAccounts" asp-action="Details" asp-route-id="@Model.AccountId">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
