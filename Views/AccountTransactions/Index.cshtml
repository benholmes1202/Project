@model IEnumerable<Project.Models.AccountTransaction>

@{
    ViewData["Title"] = "Transactions";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h1 class="h2 mb-1">Transactions</h1>
        <p class="text-muted mb-0">Captured account debits and credits.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Create Transaction</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No transactions have been captured yet.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Account</th>
                    <th>Type</th>
                    <th>Amount</th>
                    <th>Transaction Date</th>
                    <th>Capture Date</th>
                    <th>Reference</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@(item.BettingAccount?.AccountNumber ?? item.AccountId.ToString())</td>
                        <td>@(item.TransactionType?.Name ?? "-")</td>
                        <td>@item.Amount.ToString("C")</td>
                        <td>@item.TransactionDate.ToString("yyyy-MM-dd")</td>
                        <td>@item.CaptureDate.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@(item.Reference ?? "-")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@item.TransactionId">Details</a>
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.TransactionId">Edit</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.TransactionId">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
