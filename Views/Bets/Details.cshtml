@model Project.Models.Bet

@{
    ViewData["Title"] = "Bet Details";
}

<h1 class="h2">Bet Details</h1>

<dl class="row">
    <dt class="col-sm-3">Match</dt>
    <dd class="col-sm-9">@(Model.BetMatch == null ? Model.Category : $"{Model.BetMatch.HomeTeam} vs {Model.BetMatch.AwayTeam}")</dd>
    <dt class="col-sm-3">Account</dt>
    <dd class="col-sm-9">@(Model.BettingAccount?.AccountNumber ?? Model.AccountId.ToString())</dd>
    <dt class="col-sm-3">Selection</dt>
    <dd class="col-sm-9">@Model.Selection</dd>
    <dt class="col-sm-3">Stake</dt>
    <dd class="col-sm-9">@Model.Amount.ToString("C")</dd>
    <dt class="col-sm-3">Odds</dt>
    <dd class="col-sm-9">@Model.Odds</dd>
    <dt class="col-sm-3">Potential Payout</dt>
    <dd class="col-sm-9">@Model.PotentialPayout.ToString("C")</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
    <dt class="col-sm-3">Placed</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
</dl>

<a class="btn btn-outline-secondary" asp-action="Index">Back to Bets</a>
