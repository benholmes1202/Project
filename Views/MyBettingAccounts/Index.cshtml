@model IEnumerable<Project.Models.BettingAccount>

@{
    ViewData["Title"] = "My Betting Accounts";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h1 class="h2 mb-1">My Betting Accounts</h1>
        <p class="text-muted mb-0">Create accounts, deposit or withdraw funds, and close accounts once the balance is zero.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Create Account</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">You do not have any betting accounts yet.</div>
}
else
{
    <div class="row g-3">
        @foreach (var account in Model)
        {
            var isOpen = account.Status.Equals("Open", StringComparison.OrdinalIgnoreCase);
            <div class="col-md-6 col-xl-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h2 class="h5 mb-1">@account.AccountNumber</h2>
                                <div class="text-muted">@account.CurrencyCode</div>
                            </div>
                            <span class="badge @(isOpen ? "bg-success" : "bg-secondary")">@account.Status</span>
                        </div>
                        <div class="display-6 mt-3">@account.Balance.ToString("C")</div>
                        <div class="text-muted small">Bets placed: @account.Bets.Count</div>
                    </div>
                    <div class="card-footer bg-white d-flex flex-wrap gap-2">
                        @if (isOpen)
                        {
                            <a class="btn btn-sm btn-outline-primary" asp-action="Deposit" asp-route-id="@account.AccountId">Deposit</a>
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Withdraw" asp-route-id="@account.AccountId">Withdraw</a>
                            <form asp-action="Close" asp-route-id="@account.AccountId" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-danger" disabled="@(account.Balance != 0m)">Close</button>
                            </form>
                        }
                        @if (account.Balance != 0m && isOpen)
                        {
                            <span class="text-muted small align-self-center">Balance must be zero to close.</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
