@model Project.ViewModels.MyBettingAccounts.AccountMoneyViewModel

@{
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "Deposit";
    ViewData["Title"] = action;
}

<h1 class="h2">@action</h1>

<dl class="row">
    <dt class="col-sm-3">Account</dt>
    <dd class="col-sm-9">@Model.AccountNumber</dd>
    <dt class="col-sm-3">Current Balance</dt>
    <dd class="col-sm-9">@Model.Balance.ToString("C")</dd>
</dl>

<div class="row">
    <div class="col-md-6 col-lg-5">
        <form asp-action="@action" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="AccountId" />
            <input type="hidden" asp-for="AccountNumber" />
            <input type="hidden" asp-for="Balance" />
            <div class="mb-3">
                <label asp-for="Amount" class="form-label"></label>
                <input asp-for="Amount" class="form-control" />
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">@action</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
