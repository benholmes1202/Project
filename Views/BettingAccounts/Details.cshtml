@model Project.Models.BettingAccount

@{
    ViewData["Title"] = "Account Details";
    var isOpen = Model.Status.Equals("Open", StringComparison.OrdinalIgnoreCase);
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h1 class="h2 mb-1">@Model.AccountNumber</h1>
        <p class="text-muted mb-0">@(Model.User == null ? "No linked user" : $"{Model.User.FirstName} {Model.User.Surname}")</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.AccountId">Edit Account</a>
        @if (isOpen)
        {
            <a class="btn btn-primary" asp-controller="AccountTransactions" asp-action="Create" asp-route-accountId="@Model.AccountId">Add Transaction</a>
            <form asp-action="Close" asp-route-id="@Model.AccountId" method="post">
                <button type="submit" class="btn btn-outline-danger">Close Account</button>
            </form>
        }
        else
        {
            <form asp-action="Reopen" asp-route-id="@Model.AccountId" method="post">
                <button type="submit" class="btn btn-outline-success">Reopen Account</button>
            </form>
        }
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Currency</dt>
    <dd class="col-sm-9">@Model.CurrencyCode</dd>
    <dt class="col-sm-3">Outstanding Balance</dt>
    <dd class="col-sm-9">@Model.Balance.ToString("C")</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
    <dt class="col-sm-3">Created</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
    <dt class="col-sm-3">Closed</dt>
    <dd class="col-sm-9">@(Model.ClosedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</dd>
</dl>

<h2 class="h4 mt-4">Transactions</h2>

@if (!Model.AccountTransactions.Any())
{
    <div class="alert alert-info">No transactions have been captured for this account.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Amount</th>
                    <th>Capture Date</th>
                    <th>Reference</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var transaction in Model.AccountTransactions.OrderByDescending(t => t.TransactionDate))
                {
                    <tr>
                        <td>@transaction.TransactionDate.ToString("yyyy-MM-dd")</td>
                        <td>@(transaction.TransactionType?.Name ?? "-")</td>
                        <td>@transaction.Amount.ToString("C")</td>
                        <td>@transaction.CaptureDate.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@(transaction.Reference ?? "-")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-controller="AccountTransactions" asp-action="Details" asp-route-id="@transaction.TransactionId">Details</a>
                            @if (isOpen)
                            {
                                <a class="btn btn-sm btn-outline-secondary" asp-controller="AccountTransactions" asp-action="Edit" asp-route-id="@transaction.TransactionId">Edit</a>
                                <a class="btn btn-sm btn-outline-danger" asp-controller="AccountTransactions" asp-action="Delete" asp-route-id="@transaction.TransactionId">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<a asp-action="Index">Back to Accounts</a>
