@model Project.Models.BettingAccount

@{
    ViewData["Title"] = "Delete Account";
    var hasHistory = Model.AccountTransactions.Any() || Model.Bets.Any();
}

<h1 class="h2">Delete Account</h1>

<div class="alert @(hasHistory ? "alert-danger" : "alert-warning")">
    @if (hasHistory)
    {
        <span>Accounts with transactions or bets cannot be deleted. Close the account instead.</span>
    }
    else
    {
        <span>Are you sure you want to delete this empty betting account?</span>
    }
</div>

<dl class="row">
    <dt class="col-sm-3">Account Number</dt>
    <dd class="col-sm-9">@Model.AccountNumber</dd>
    <dt class="col-sm-3">Owner</dt>
    <dd class="col-sm-9">@(Model.User == null ? "-" : $"{Model.User.FirstName} {Model.User.Surname}")</dd>
    <dt class="col-sm-3">Balance</dt>
    <dd class="col-sm-9">@Model.Balance.ToString("C")</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="AccountId" />
    @if (!hasHistory)
    {
        <button type="submit" class="btn btn-danger">Delete</button>
    }
    <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.AccountId">Back to Account</a>
</form>
