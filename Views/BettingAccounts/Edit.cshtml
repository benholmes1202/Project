@model Project.ViewModels.BettingAccounts.BettingAccountFormViewModel

@{
    ViewData["Title"] = "Edit Account";
}

<h1 class="h2">Edit Betting Account</h1>

<div class="row">
    <div class="col-md-6 col-lg-5">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="AccountId" />
            <div class="mb-3">
                <label asp-for="UserId" class="form-label"></label>
                <select asp-for="UserId" class="form-select" asp-items="ViewBag.UserId"></select>
                <span asp-validation-for="UserId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="AccountNumber" class="form-label"></label>
                <input asp-for="AccountNumber" class="form-control" />
                <span asp-validation-for="AccountNumber" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="CurrencyCode" class="form-label"></label>
                <input asp-for="CurrencyCode" class="form-control" maxlength="3" />
                <span asp-validation-for="CurrencyCode" class="text-danger"></span>
            </div>
            <dl class="row">
                <dt class="col-sm-5">Outstanding Balance</dt>
                <dd class="col-sm-7">@Model.Balance.ToString("C")</dd>
                <dt class="col-sm-5">Status</dt>
                <dd class="col-sm-7">@Model.Status</dd>
            </dl>
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.AccountId">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
