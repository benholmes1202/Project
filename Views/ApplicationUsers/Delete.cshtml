@model Project.Models.ApplicationUser

@{
    ViewData["Title"] = "Delete User";
    var canDelete = ViewBag.CanDelete as bool? ?? false;
}

<h1 class="h2">Delete User</h1>

<div class="alert @(canDelete ? "alert-warning" : "alert-danger")">
    @if (canDelete)
    {
        <span>This user can be deleted because they have no open betting accounts.</span>
    }
    else
    {
        <span>This user cannot be deleted while they have open betting accounts.</span>
    }
</div>

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.FirstName @Model.Surname</dd>
    <dt class="col-sm-3">ID Number</dt>
    <dd class="col-sm-9">@Model.IdNumber</dd>
    <dt class="col-sm-3">Linked Accounts</dt>
    <dd class="col-sm-9">@Model.BettingAccounts.Count</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="UserId" />
    @if (canDelete)
    {
        <button type="submit" class="btn btn-danger">Delete</button>
    }
    <a class="btn btn-outline-secondary" asp-action="Index">Back to Users</a>
</form>
