@model Project.Models.ApplicationUser

@{
    ViewData["Title"] = "User Details";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h1 class="h2 mb-1">@Model.FirstName @Model.Surname</h1>
        <p class="text-muted mb-0">ID Number: @Model.IdNumber</p>
    </div>
    <div>
        <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.UserId">Edit User</a>
        <a class="btn btn-primary" asp-controller="BettingAccounts" asp-action="Create" asp-route-userId="@Model.UserId">Add Account</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>
    <dt class="col-sm-3">Phone</dt>
    <dd class="col-sm-9">@(Model.PhoneNumber ?? "-")</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@(Model.IsActive ? "Active" : "Inactive")</dd>
</dl>

<h2 class="h4 mt-4">Linked Accounts</h2>

@if (!Model.BettingAccounts.Any())
{
    <div class="alert alert-info">This user does not have any betting accounts yet.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Account Number</th>
                    <th>Currency</th>
                    <th>Balance</th>
                    <th>Status</th>
                    <th>Transactions</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var account in Model.BettingAccounts.OrderBy(a => a.AccountNumber))
                {
                    <tr>
                        <td>@account.AccountNumber</td>
                        <td>@account.CurrencyCode</td>
                        <td>@account.Balance.ToString("C")</td>
                        <td>@account.Status</td>
                        <td>@account.AccountTransactions.Count</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-controller="BettingAccounts" asp-action="Details" asp-route-id="@account.AccountId">Details</a>
                            <a class="btn btn-sm btn-outline-secondary" asp-controller="BettingAccounts" asp-action="Edit" asp-route-id="@account.AccountId">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<a asp-action="Index">Back to Users</a>
